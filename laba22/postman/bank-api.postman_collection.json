              "path": [
                "api",
                "accounts",
                "{{accountId}}"
              ]
            },
            "description": "Получение счёта по идентификатору"
          }
        },
        {
          "name": "Изменить счёт",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"number\": \"ACC-100001-UPDATED\",\n  \"balance\": 2500.00,\n  \"customer\": {\n    \"id\": {{customerId}}\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "accounts",
                "{{accountId}}"
              ]
            },
            "description": "Обновление данных счёта"
          }
        },
        {
          "name": "Удалить счёт",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "accounts",
                "{{accountId}}"
              ]
            },
            "description": "Удаление счёта по идентификатору"
          }
        }
      ]
    },
    {
      "name": "3. Карты",
