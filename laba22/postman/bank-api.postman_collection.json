              "raw": "{\n  \"number\": \"4222222222222222\",\n  \"blocked\": true,\n  \"account\": {\n    \"id\": {{accountId}}\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cards/{{cardId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
