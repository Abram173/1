    },
    {
      "name": "5. Бизнес-операции",
      "description": "Операции прикладной логики банка",
      "item": [
        {
          "name": "Открыть счёт клиенту",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": {{customerId}},\n  \"accountNumber\": \"ACC-BUSINESS-001\",\n  \"initialBalance\": 5000.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/operations/open-account",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "operations",
                "open-account"
              ]
            },
            "description": "Открытие нового счёта для существующего клиента"
          }
        },
        {
          "name": "Выпустить карту к счёту",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": {{accountId}},\n  \"cardNumber\": \"5333444455556666\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/operations/issue-card",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "operations",
                "issue-card"
              ]
            },
            "description": "Выпуск банковской карты для существующего счёта"
          }
        },
        {
          "name": "Пополнить счёт",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1000.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/operations/deposit/{{accountId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "operations",
                "deposit",
                "{{accountId}}"
              ]
            },
            "description": "Пополнение баланса выбранного счёта"
          }
        },
        {
          "name": "Снять деньги со счёта",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 250.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/operations/withdraw/{{accountId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "operations",
                "withdraw",
                "{{accountId}}"
              ]
            },
            "description": "Списание средств со счёта"
          }
        },
        {
          "name": "Перевести деньги между счетами",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountId\": {{accountId}},\n  \"toAccountId\": {{secondAccountId}},\n  \"amount\": 700.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/operations/transfer",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "operations",
                "transfer"
              ]
            },
            "description": "Перевод денег с одного счёта на другой"
