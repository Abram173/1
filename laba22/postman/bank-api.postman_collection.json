              "raw": "{\n  \"fromAccount\": {\n    \"id\": {{accountId}}\n  },\n  \"toAccount\": {\n    \"id\": {{secondAccountId}}\n  },\n  \"amount\": 450.00,\n  \"createdAt\": \"2026-03-10T13:30:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions/{{transactionId}}",
