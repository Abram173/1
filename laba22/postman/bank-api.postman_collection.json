    {
      "name": "4. Транзакции",
      "description": "CRUD-операции для сущности Transaction",
      "item": [
        {
          "name": "Создать транзакцию",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccount\": {\n    \"id\": {{accountId}}\n  },\n  \"toAccount\": {\n    \"id\": {{secondAccountId}}\n  },\n  \"amount\": 300.00,\n  \"createdAt\": \"2026-03-10T12:00:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions",
              "host": [
                "{{baseUrl}}"
              ],
