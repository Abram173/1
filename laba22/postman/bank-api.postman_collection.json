{
  "info": {
    "name": "Банковский REST API",
    "description": "Коллекция запросов для лабораторной работы по REST API. Содержит CRUD-операции для клиентов, счетов, карт и транзакций, а также бизнес-операции банка.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "customerId",
      "value": "1"
    },
    {
      "key": "accountId",
      "value": "1"
    },
    {
      "key": "secondAccountId",
      "value": "2"
    },
    {
      "key": "cardId",
      "value": "1"
    },
    {
      "key": "transactionId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "1. Клиенты",
      "description": "CRUD-операции для сущности Customer",
      "item": [
        {
          "name": "Создать клиента",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Иван\",\n  \"lastName\": \"Иванов\",\n  \"email\": \"ivanov@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "customers"
              ]
            },
            "description": "Создание нового клиента банка"
          }
        },
        {
          "name": "Получить всех клиентов",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/customers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "customers"
              ]
            },
            "description": "Получение списка всех клиентов"
          }
        },
        {
          "name": "Получить клиента по ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/customers/{{customerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "customers",
                "{{customerId}}"
              ]
            },
            "description": "Получение клиента по идентификатору"
          }
        },
        {
          "name": "Изменить клиента",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Пётр\",\n  \"lastName\": \"Петров\",\n  \"email\": \"petrov@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers/{{customerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "customers",
                "{{customerId}}"
              ]
            },
            "description": "Обновление данных клиента"
          }
        },
        {
          "name": "Удалить клиента",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/customers/{{customerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "customers",
                "{{customerId}}"
              ]
            },
            "description": "Удаление клиента по идентификатору"
          }
        }
      ]
    },
    {
      "name": "2. Счета",
      "description": "CRUD-операции для сущности Account",
      "item": [
        {
          "name": "Создать счёт",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"number\": \"ACC-100001\",\n  \"balance\": 1500.00,\n  \"customer\": {\n    \"id\": {{customerId}}\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/accounts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "accounts"
              ]
            },
            "description": "Создание нового банковского счёта"
          }
        },
        {
          "name": "Получить все счета",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/accounts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "accounts"
              ]
            },
            "description": "Получение списка всех счетов"
          }
        },
        {
          "name": "Получить счёт по ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}",
              "host": [
                "{{baseUrl}}"
